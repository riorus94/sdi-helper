# Storage backend: local | s3
STORAGE_BACKEND=local

# Local storage root (used when STORAGE_BACKEND=local)
LOCAL_DATASET_ROOT=./dataset_raw

# AWS S3 settings (used when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
S3_BUCKET=
S3_PREFIX=datasets/cars/v1

# Optional: override Chrome driver path (auto-detected if blank)
CHROMEDRIVER_PATH=

# Optional LLM context compression
HEADROOM_ENABLED=true
HEADROOM_MODEL=gpt-4-0613
